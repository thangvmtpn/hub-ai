# ═══════════════════════════════════════════════════
# AI AGENT HUB - Environment Configuration
# ═══════════════════════════════════════════════════

# Anthropic API Key (bắt buộc)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Gemini API Key (bắt buộc cho mô hình tạo ảnh Nano Banana 2 / Imagen 3)
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Secret - dùng để mã hóa session token
# Tạo bằng: openssl rand -hex 32
JWT_SECRET=your-random-secret-here-change-this

# Danh sách users (JSON array)
# Format: [{"username":"admin","password":"hash","name":"Admin","role":"admin","department":"all"}]
# Chạy: npm run seed  để tạo file users.json
USERS_FILE=./users.json

# App config
NEXT_PUBLIC_APP_NAME="AI Agent Hub"
NEXT_PUBLIC_APP_URL=https://ai.yourdomain.com
